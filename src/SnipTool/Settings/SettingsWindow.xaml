<Window x:Class="SnipTool.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snip Tool Settings" Width="470" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="14">
        <TextBlock Text="Hotkey" FontWeight="Bold"/>
        <TextBox x:Name="HotkeyBox" IsReadOnly="True" Margin="0,2,0,10"
                 PreviewKeyDown="HotkeyBox_PreviewKeyDown" ToolTip="Click and press a key combo"/>

        <TextBlock Text="Save folder" FontWeight="Bold"/>
        <DockPanel Margin="0,2,0,10">
            <Button x:Name="BrowseBtn" Content="Browse…" DockPanel.Dock="Right" Width="84"
                    Margin="8,0,0,0" Click="Browse_Click"/>
            <TextBox x:Name="FolderBox"/>
        </DockPanel>

        <TextBlock Text="Filename pattern" FontWeight="Bold"/>
        <TextBox x:Name="PatternBox" Margin="0,2,0,2" TextChanged="Pattern_Changed"/>
        <TextBlock x:Name="PreviewText" Foreground="Gray" Margin="0,0,0,10"/>

        <TextBlock Text="Image format" FontWeight="Bold"/>
        <ComboBox x:Name="FormatBox" Width="110" HorizontalAlignment="Left" Margin="0,2,0,10"
                  SelectionChanged="Format_Changed">
            <ComboBoxItem Content="png"/>
            <ComboBoxItem Content="jpg"/>
        </ComboBox>

        <CheckBox x:Name="StartupCheck" Content="Run at Windows startup" Margin="0,0,0,12"/>

        <DockPanel>
            <Button x:Name="DisableSnipBtn" Content="Disable Windows PrtSc→Snip" DockPanel.Dock="Left"
                    Width="190" Click="DisableSnip_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="84" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="Save" Width="84" Click="Save_Click" IsDefault="True"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
