<Window x:Class="SnipTool.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="#01000000" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" Cursor="Cross"
        KeyDown="OnKeyDown">
    <Grid>
        <Image x:Name="FrozenImage" Stretch="Fill"/>
        <Rectangle x:Name="Dim" Fill="#66000000"/>
        <Canvas x:Name="Overlay" Background="Transparent"
                MouseLeftButtonDown="OnMouseDown"
                MouseMove="OnMouseMove"
                MouseLeftButtonUp="OnMouseUp">
            <Rectangle x:Name="SelRect" Stroke="#4DA3FF" StrokeThickness="2" Visibility="Collapsed"/>
        </Canvas>
    </Grid>
</Window>
