<UserControl x:Class="Aquashot.Editor.InlineToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="10" Padding="6" Background="{StaticResource B.Surface}"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="ModeImage" GroupName="omode" Style="{StaticResource ModeChip}" Content="PNG" ToolTip="Screenshot (annotate &amp; save)"/>
            <RadioButton x:Name="ModeGif"   GroupName="omode" Style="{StaticResource ModeChip}" Content="GIF" ToolTip="Record a GIF of this region"/>
            <RadioButton x:Name="ModeVideo" GroupName="omode" Style="{StaticResource ModeChip}" Content="MP4" ToolTip="Record a video of this region"/>
            <Border Width="1" Background="{StaticResource B.Border}" Margin="6,5"/>

            <RadioButton x:Name="ToolSelect"  GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Cursor}"  ToolTip="Select / move (drag items, Del to delete)"/>
            <RadioButton x:Name="ToolArrow"   GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Arrow}"   ToolTip="Arrow"/>
            <RadioButton x:Name="ToolRect"    GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Square}"  ToolTip="Rectangle"/>
            <RadioButton x:Name="ToolEllipse" GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Circle}"  ToolTip="Ellipse"/>
            <RadioButton x:Name="ToolLine"    GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Line}"    ToolTip="Line"/>
            <RadioButton x:Name="ToolPen"     GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Pencil}"  ToolTip="Pen"/>
            <RadioButton x:Name="ToolText"    GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Text}"    ToolTip="Text"/>
            <RadioButton x:Name="ToolCounter" GroupName="tool" Style="{StaticResource ToolToggle}" Tag="{StaticResource Icon.Counter}" ToolTip="Numbered step"/>

            <Border Width="1" Background="{StaticResource B.Border}" Margin="6,5"/>

            <StackPanel x:Name="ColorPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
            <Slider x:Name="WidthSlider" Width="84" Minimum="1" Maximum="12" Value="3"
                    VerticalAlignment="Center" Margin="8,0" ToolTip="Size (scroll wheel)"
                    Foreground="{StaticResource B.Accent}"/>
            <ToggleButton x:Name="FillToggle" Style="{StaticResource IconToggle}"
                          Tag="{StaticResource Icon.Fill}" ToolTip="Fill shape"/>

            <Border Width="1" Background="{StaticResource B.Border}" Margin="6,5"/>

            <Button x:Name="BtnUndo"    Style="{StaticResource IconButton}" Tag="{StaticResource Icon.Undo}"  ToolTip="Undo (Ctrl+Z)"/>
            <Button x:Name="BtnRedo"    Style="{StaticResource IconButton}" Tag="{StaticResource Icon.Redo}"  ToolTip="Redo (Ctrl+Y)"/>
            <Button x:Name="BtnConfirm" Style="{StaticResource IconButton}" Tag="{StaticResource Icon.Check}"
                    Foreground="{StaticResource B.Success}" ToolTip="Copy &amp; save (Enter / Ctrl+C)"/>
            <Button x:Name="BtnCancel"  Style="{StaticResource IconButton}" Tag="{StaticResource Icon.X}"
                    Foreground="{StaticResource B.Danger}" ToolTip="Cancel (Esc)"/>
        </StackPanel>
    </Border>
</UserControl>
