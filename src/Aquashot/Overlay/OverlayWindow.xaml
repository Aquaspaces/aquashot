<Window x:Class="Aquashot.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" Cursor="Cross"
        UseLayoutRounding="True"
        KeyDown="OnKeyDown">
    <Grid>
        <Image x:Name="FrozenImage" Stretch="Fill"/>
        <Rectangle x:Name="Dim" Fill="#66000000"/>
        <Canvas x:Name="Overlay" Background="Transparent"
                MouseLeftButtonDown="OnMouseDown"
                MouseMove="OnMouseMove"
                MouseLeftButtonUp="OnMouseUp"
                MouseWheel="OnMouseWheel">
            <Rectangle x:Name="SelRect" Stroke="#4DA3FF" StrokeThickness="2"
                       StrokeDashArray="4 3" Visibility="Collapsed"/>
            <Rectangle x:Name="WinRect" Stroke="#4DFFA3" StrokeThickness="2"
                       Fill="#224DFFA3" Visibility="Collapsed"/>
            <Border x:Name="DimLabel" Background="#CC1C1C22" CornerRadius="3" Padding="5,2" Visibility="Collapsed">
                <TextBlock x:Name="DimText" Foreground="White" FontSize="12"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
