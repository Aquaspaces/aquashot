<Window x:Class="Aquashot.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="False"
        Background="Black" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" Cursor="Cross"
        UseLayoutRounding="True"
        KeyDown="OnKeyDown">
    <Grid>
        <Image x:Name="FrozenImage" Stretch="Fill"/>
        <Rectangle x:Name="Dim" Fill="#66000000"/>
        <Canvas x:Name="Overlay" Background="Transparent"
                MouseLeftButtonDown="OnMouseDown"
                MouseMove="OnMouseMove"
                MouseLeftButtonUp="OnMouseUp"
                MouseWheel="OnMouseWheel">
            <Rectangle x:Name="SelRect" Stroke="#4DA3FF" StrokeThickness="2"
                       StrokeDashArray="4 3" Visibility="Collapsed"/>
            <Rectangle x:Name="WinRect" Stroke="#4DFFA3" StrokeThickness="2"
                       Fill="#224DFFA3" Visibility="Collapsed"/>
            <Border x:Name="DimLabel" Background="#CC1C1C22" CornerRadius="3" Padding="5,2" Visibility="Collapsed">
                <TextBlock x:Name="DimText" Foreground="White" FontSize="12"/>
            </Border>
        </Canvas>

        <!-- Capture-mode picker, shown at the top until a region is committed. -->
        <Border x:Name="ModeBar" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,14,0,0"
                Background="{StaticResource B.Surface}" CornerRadius="9" Padding="5"
                BorderBrush="{StaticResource B.Border}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.5" Color="#000000"/>
            </Border.Effect>
            <Button x:Name="ModeButton" Style="{StaticResource GhostButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ModeLabel" Text="Region capture"/>
                    <TextBlock Text="&#x25BE;" Margin="8,0,0,0" Opacity="0.7"/>
                </StackPanel>
                <Button.ContextMenu>
                    <ContextMenu x:Name="ModeMenu">
                        <MenuItem Header="Region capture"  Click="ModeRegion_Click"/>
                        <MenuItem Header="Window capture"  Click="ModeWindow_Click"/>
                        <MenuItem Header="Monitor capture" Click="ModeMonitor_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Border>
    </Grid>
</Window>
