<Window x:Class="Aquashot.Overlay.CountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" SizeToContent="WidthAndHeight"
        IsHitTestVisible="False" Focusable="False"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Border CornerRadius="100" Width="160" Height="160"
            Background="#CC1C1C22" BorderBrush="{StaticResource B.Accent}" BorderThickness="3">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.7" Color="#000000"/>
        </Border.Effect>
        <TextBlock x:Name="CountText" Text="3"
                   FontSize="84" FontWeight="Bold" Foreground="{StaticResource B.Text}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
</Window>
