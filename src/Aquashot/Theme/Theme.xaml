<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Palette ============ -->
    <SolidColorBrush x:Key="B.Surface"     Color="#1F1F29"/>
    <SolidColorBrush x:Key="B.SurfaceAlt"  Color="#2A2A36"/>
    <SolidColorBrush x:Key="B.Hover"       Color="#34344300"/>
    <SolidColorBrush x:Key="B.HoverSolid"  Color="#343445"/>
    <SolidColorBrush x:Key="B.Accent"      Color="#3B82F6"/>
    <SolidColorBrush x:Key="B.AccentHover" Color="#5B9BFF"/>
    <SolidColorBrush x:Key="B.Text"        Color="#E6E8EE"/>
    <SolidColorBrush x:Key="B.TextDim"     Color="#9AA0AD"/>
    <SolidColorBrush x:Key="B.Icon"        Color="#D6D9E0"/>
    <SolidColorBrush x:Key="B.Border"      Color="#3A3A47"/>
    <SolidColorBrush x:Key="B.Danger"      Color="#F26D6D"/>
    <SolidColorBrush x:Key="B.Success"     Color="#46C46A"/>

    <!-- ============ Icon geometries (Lucide, ISC) ============ -->
    <PathGeometry x:Key="Icon.Cursor" Figures="M4.037 4.688a.495.495 0 0 1 .651-.651l16 6.5a.5.5 0 0 1-.063.947l-6.124 1.58a2 2 0 0 0-1.438 1.435l-1.579 6.126a.5.5 0 0 1-.947.063z"/>
    <GeometryGroup x:Key="Icon.Arrow">
        <PathGeometry Figures="M7 7h10v10"/>
        <PathGeometry Figures="M7 17 17 7"/>
    </GeometryGroup>
    <RectangleGeometry x:Key="Icon.Square" Rect="3,3,18,18" RadiusX="2" RadiusY="2"/>
    <EllipseGeometry x:Key="Icon.Circle" Center="12,12" RadiusX="10" RadiusY="10"/>
    <PathGeometry x:Key="Icon.Line" Figures="M5 12h14"/>
    <GeometryGroup x:Key="Icon.Pencil">
        <PathGeometry Figures="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/>
        <PathGeometry Figures="m15 5 4 4"/>
    </GeometryGroup>
    <GeometryGroup x:Key="Icon.Text">
        <PathGeometry Figures="M12 4v16"/>
        <PathGeometry Figures="M4 7V5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2"/>
        <PathGeometry Figures="M9 20h6"/>
    </GeometryGroup>
    <GeometryGroup x:Key="Icon.Counter">
        <PathGeometry Figures="M11 5h10"/>
        <PathGeometry Figures="M11 12h10"/>
        <PathGeometry Figures="M11 19h10"/>
        <PathGeometry Figures="M4 4h1v5"/>
        <PathGeometry Figures="M4 9h2"/>
        <PathGeometry Figures="M6.5 20H3.4c0-1 2.6-1.925 2.6-3.5a1.5 1.5 0 0 0-2.6-1.02"/>
    </GeometryGroup>
    <GeometryGroup x:Key="Icon.Undo">
        <PathGeometry Figures="M9 14 4 9l5-5"/>
        <PathGeometry Figures="M4 9h10.5a5.5 5.5 0 0 1 5.5 5.5a5.5 5.5 0 0 1-5.5 5.5H11"/>
    </GeometryGroup>
    <GeometryGroup x:Key="Icon.Redo">
        <PathGeometry Figures="m15 14 5-5-5-5"/>
        <PathGeometry Figures="M20 9H9.5A5.5 5.5 0 0 0 4 14.5A5.5 5.5 0 0 0 9.5 20H13"/>
    </GeometryGroup>
    <RectangleGeometry x:Key="Icon.Fill" Rect="4,4,16,16" RadiusX="2" RadiusY="2"/>
    <PathGeometry x:Key="Icon.Check" Figures="M20 6 9 17l-5-5"/>
    <GeometryGroup x:Key="Icon.X">
        <PathGeometry Figures="M18 6 6 18"/>
        <PathGeometry Figures="m6 6 12 12"/>
    </GeometryGroup>

    <!-- ============ Tool toggle (RadioButton) ============ -->
    <Style x:Key="ToolToggle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource B.Icon}"/>
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="7">
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="{TemplateBinding Tag}" Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverSolid}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Accent}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Icon toggle (ToggleButton) — filled-icon look ============ -->
    <Style x:Key="IconToggle" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{StaticResource B.Icon}"/>
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="7">
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="{TemplateBinding Tag}" Fill="{TemplateBinding Foreground}"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverSolid}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Accent}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Icon action button (Button) ============ -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource B.Icon}"/>
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="7">
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="{TemplateBinding Tag}" Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverSolid}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Color swatch (RadioButton) ============ -->
    <Style x:Key="Swatch" TargetType="RadioButton">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" CornerRadius="5" Background="{TemplateBinding Background}"
                            BorderBrush="Transparent" BorderThickness="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#88FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Buttons (text) ============ -->
    <Style x:Key="ModernButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource B.Accent}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="14,7">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="Background" Value="{StaticResource B.SurfaceAlt}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="14,7"
                            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverSolid}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Inputs (implicit) ============ -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource B.SurfaceAlt}"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource B.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="7,5"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

</ResourceDictionary>
