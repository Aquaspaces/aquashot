<Window x:Class="Aquashot.History.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:Aquashot.History"
        Title="Aquashot — History" Width="1000" Height="680"
        Background="{StaticResource B.Surface}">
  <DockPanel Margin="10">
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <TextBlock Text="Size" VerticalAlignment="Center" Margin="0,0,6,0"
                 Foreground="{StaticResource B.Text}" DockPanel.Dock="Right"/>
      <Slider x:Name="SizeSlider" Minimum="120" Maximum="480" Width="160"
              VerticalAlignment="Center" DockPanel.Dock="Right"/>
      <TextBox x:Name="SearchBox" VerticalContentAlignment="Center" Height="30"
               ToolTip="Search file names and text inside screenshots"/>
    </DockPanel>

    <Grid>
      <ListBox x:Name="Grid" BorderThickness="0" Background="Transparent"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Width="{Binding DataContext.TileSize, RelativeSource={RelativeSource AncestorType=Window}}" Margin="6">
              <StackPanel.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Open" Click="Open_Click"/>
                  <MenuItem Header="Copy" Click="Copy_Click"/>
                  <MenuItem Header="Reveal in folder" Click="Reveal_Click"/>
                  <MenuItem Header="Delete" Click="Delete_Click"/>
                </ContextMenu>
              </StackPanel.ContextMenu>
              <Image Source="{Binding Thumb}"
                     Height="{Binding DataContext.TileImageHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                     Stretch="Uniform"/>
              <TextBlock Text="{Binding Name}" Foreground="{StaticResource B.Text}" TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="{Binding Date}" Foreground="{StaticResource B.Text}" Opacity="0.6" FontSize="11"/>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <DockPanel x:Name="DetailPanel" Visibility="Collapsed" Background="{StaticResource B.Surface}">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
          <Button x:Name="BtnPrev" Content="◀" Width="36" ToolTip="Previous (←)"/>
          <Button x:Name="BtnNext" Content="▶" Width="36" Margin="4,0" ToolTip="Next (→)"/>
          <Button x:Name="BtnClose" Content="Close" DockPanel.Dock="Right" ToolTip="Back to grid (Esc)"/>
          <Button x:Name="BtnCopyText" Content="Copy all text" DockPanel.Dock="Right" Margin="4,0"/>
          <Button x:Name="BtnCopyImage" Content="Copy image" DockPanel.Dock="Right" Margin="4,0"/>
          <TextBlock x:Name="DetailTitle" VerticalAlignment="Center" Margin="8,0"
                     Foreground="{StaticResource B.Text}" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
        <h:OcrTextOverlay x:Name="Overlay"/>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
