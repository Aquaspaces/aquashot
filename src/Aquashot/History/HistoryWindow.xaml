<Window x:Class="Aquashot.History.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aquashot — History" Width="900" Height="600"
        Background="{StaticResource B.Surface}">
  <DockPanel Margin="10">
    <TextBox x:Name="SearchBox" DockPanel.Dock="Top" Margin="0,0,0,8"
             VerticalContentAlignment="Center" Height="30"
             ToolTip="Search file names and text inside screenshots"/>
    <ListBox x:Name="Grid" BorderThickness="0" Background="Transparent"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="ContextMenu">
            <Setter.Value>
              <ContextMenu>
                <MenuItem Header="Open" Click="Open_Click"/>
                <MenuItem Header="Copy" Click="Copy_Click"/>
                <MenuItem Header="Reveal in folder" Click="Reveal_Click"/>
                <MenuItem Header="Delete" Click="Delete_Click"/>
              </ContextMenu>
            </Setter.Value>
          </Setter>
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <StackPanel Width="240" Margin="6">
            <Image Source="{Binding Thumb}" Height="150" Stretch="Uniform"/>
            <TextBlock Text="{Binding Name}" Foreground="{StaticResource B.Text}" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding Date}" Foreground="{StaticResource B.Text}" Opacity="0.6" FontSize="11"/>
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
