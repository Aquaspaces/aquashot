<Window x:Class="Aquashot.Capture.ScrollingCapture.ScrollRegionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="#01000000" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" Cursor="Cross"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <!-- Full-virtual-desktop dim overlay; the user drags a rectangle to pick the scroll region.
         A near-transparent (#01) background keeps the window hit-testable while showing the desktop
         beneath. The dim + selection rect are drawn on the canvas in code-behind. -->
    <Grid>
        <Canvas x:Name="Root">
            <Rectangle x:Name="DimTop"    Fill="#66000000"/>
            <Rectangle x:Name="DimBottom" Fill="#66000000"/>
            <Rectangle x:Name="DimLeft"   Fill="#66000000"/>
            <Rectangle x:Name="DimRight"  Fill="#66000000"/>
            <Rectangle x:Name="SelRect" Stroke="#3B82F6" StrokeThickness="2" Visibility="Collapsed"/>
            <Border x:Name="Hint" Canvas.Left="24" Canvas.Top="24"
                    Background="#CC1F1F29" CornerRadius="8" Padding="14,10" Visibility="Visible">
                <TextBlock Text="Drag to pick the area to scroll-capture · Esc to cancel"
                           Foreground="#E6E8EE" FontSize="13"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
