<Window x:Class="Aquashot.Capture.ScrollingCapture.ScrollProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" ShowActivated="False" SizeToContent="WidthAndHeight"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <!-- Small toast in a screen corner (kept OUT of the captured region so it isn't stitched in).
         Shows progress and a Cancel; Esc also cancels (handled in code-behind). -->
    <Border Background="{StaticResource B.Surface}" BorderBrush="{StaticResource B.Border}"
            BorderThickness="1" CornerRadius="10" Padding="16,12">
        <StackPanel>
            <TextBlock Text="Scrolling capture…" Foreground="{StaticResource B.Text}"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatusText" Text="Grabbing frame 1…"
                       Foreground="{StaticResource B.TextDim}" FontSize="12" Margin="0,0,0,10"/>
            <Button x:Name="CancelBtn" Content="Cancel (Esc)" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" Click="Cancel_Click"/>
        </StackPanel>
    </Border>
</Window>
