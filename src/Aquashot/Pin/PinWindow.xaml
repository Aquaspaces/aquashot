<Window x:Class="Aquashot.Pin.PinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize" Title="Aquashot Pin"
        ToolTip="Drag to move · scroll to zoom · Ctrl+C to copy · Esc / right-click to close">
    <Border x:Name="Frame" BorderBrush="{StaticResource B.Accent}" BorderThickness="2" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Image x:Name="Img" Stretch="Fill"/>
    </Border>
</Window>
