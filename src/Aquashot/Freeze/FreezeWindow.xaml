<Window x:Class="Aquashot.Freeze.FreezeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" Background="Black"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        MouseDown="OnDismiss" KeyDown="OnKey">
    <Grid>
        <Image x:Name="FrozenImage" Stretch="Fill"/>
        <Border x:Name="Hint" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,18,0,0"
                Background="#DD1F1F29" CornerRadius="9" Padding="14,7"
                BorderBrush="{StaticResource B.Border}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.5" Color="#000000"/>
            </Border.Effect>
            <TextBlock Text="⏸  Desktop frozen — press Esc or click to resume"
                       Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</Window>
